<Window x:Class="HttpLoadTester.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        mc:Ignorable="d"
        Title="Система нагрузочного тестирования HTTP-серверов"
        Height="920"
        Width="1500"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="1.4*"/>
            <RowDefinition Height="1.2*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardStyle}" Grid.Row="0">
            <DockPanel>
                <StackPanel>
                    <TextBlock Text="Система нагрузочного тестирования HTTP-серверов"
                               FontSize="24"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Конфигурация теста" FontSize="18" FontWeight="SemiBold"/>

                        <TextBlock Text="Сохранённые конфигурации"/>
                        <ComboBox ItemsSource="{Binding Configurations}"
                                  SelectedItem="{Binding SelectedSavedConfiguration}"
                                  DisplayMemberPath="TestName"/>

                        <TextBlock Text="Название теста"/>
                        <TextBox Text="{Binding CurrentConfiguration.TestName, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="URL"/>
                        <TextBox Text="{Binding CurrentConfiguration.Url, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="HTTP-метод"/>
                        <ComboBox SelectedValue="{Binding CurrentConfiguration.HttpMethod, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="Content">
                            <ComboBoxItem Content="GET"/>
                            <ComboBoxItem Content="POST"/>
                            <ComboBoxItem Content="PUT"/>
                            <ComboBoxItem Content="DELETE"/>
                        </ComboBox>

                        <TextBlock Text="Headers (JSON)"/>
                        <TextBox Text="{Binding CurrentConfiguration.Headers, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 Height="90"
                                 VerticalScrollBarVisibility="Auto"/>

                        <TextBlock Text="Body"/>
                        <TextBox Text="{Binding CurrentConfiguration.Body, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 Height="90"
                                 VerticalScrollBarVisibility="Auto"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Пользователи"/>
                                <TextBox Text="{Binding CurrentConfiguration.ConcurrentUsers}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Длительность, сек"/>
                                <TextBox Text="{Binding CurrentConfiguration.DurationSeconds}"/>
                            </StackPanel>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Ramp-Up, сек"/>
                                <TextBox Text="{Binding CurrentConfiguration.RampUpSeconds}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Timeout, мс"/>
                                <TextBox Text="{Binding CurrentConfiguration.TimeoutMilliseconds}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Описание"/>
                        <TextBox Text="{Binding CurrentConfiguration.Description}"
                                 AcceptsReturn="True"
                                 Height="80"/>

                        <WrapPanel Margin="0,10,0,0">
                            <Button Content="Сохранить"
                                    Command="{Binding SaveConfigurationCommand}"/>
                            <Button Content="Удалить"
                                    Command="{Binding DeleteConfigurationCommand}"
                                    Background="#EF4444"/>
                            <Button Content="Обновить"
                                    Command="{Binding LoadConfigurationsCommand}"
                                    Background="#6B7280"/>
                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Управление запуском" FontSize="18" FontWeight="SemiBold"/>
                        <WrapPanel>
                            <Button Content="Запустить тест"
                                    Command="{Binding StartTestCommand}"/>
                            <Button Content="Остановить"
                                    Command="{Binding StopTestCommand}"
                                    Background="#EF4444"/>
                            <Button Content="Загрузить результаты"
                                    Command="{Binding LoadResultsCommand}"
                                    Background="#6B7280"/>
                        </WrapPanel>

                        <ProgressBar Height="18"
                                     Margin="0,8,0,0"
                                     Value="{Binding ProgressPercent}"
                                     Maximum="100"/>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="180"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <UniformGrid Grid.Row="0" Columns="4">
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Всего запросов" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding TotalRequests}" FontSize="28" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="RPS" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding LiveRps}" FontSize="28" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Среднее время, мс" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding LiveAverageResponse}" FontSize="28" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Успешность, %" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding SuccessRate}" FontSize="28" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="График времени ответа" FontSize="18" FontWeight="SemiBold"/>
                            <lvc:CartesianChart Series="{Binding ResponseSeries}" LegendLocation="Right" Height="300">
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis Title="Запрос"/>
                                </lvc:CartesianChart.AxisX>
                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis Title="мс"/>
                                </lvc:CartesianChart.AxisY>
                            </lvc:CartesianChart>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Последние запросы" FontSize="18" FontWeight="SemiBold"/>
                    <DataGrid ItemsSource="{Binding RecentLogs}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Height="220">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding RequestNumber}" Width="80"/>
                            <DataGridTextColumn Header="Время, мс" Binding="{Binding ResponseTimeMs}" Width="100"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding StatusCode}" Width="90"/>
                            <DataGridCheckBoxColumn Header="Успех" Binding="{Binding Success}" Width="80"/>
                            <DataGridTextColumn Header="Время" Binding="{Binding Timestamp}" Width="160"/>
                            <DataGridTextColumn Header="Ошибка" Binding="{Binding ErrorMessage}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="3" Style="{StaticResource CardStyle}">
            <StackPanel>
                <DockPanel>
                    <TextBlock Text="История результатов" FontSize="18" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                    <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                        <Button Content="Экспорт CSV"
                                Command="{Binding ExportCsvCommand}"/>
                        <Button Content="Экспорт JSON"
                                Command="{Binding ExportJsonCommand}"
                                Background="#10B981"/>
                    </WrapPanel>
                </DockPanel>

                <DataGrid ItemsSource="{Binding Results}"
                          SelectedItem="{Binding SelectedResult}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Height="220">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                        <DataGridTextColumn Header="Тест" Binding="{Binding TestName}" Width="220"/>
                        <DataGridTextColumn Header="Старт" Binding="{Binding StartTime}" Width="150"/>
                        <DataGridTextColumn Header="Финиш" Binding="{Binding EndTime}" Width="150"/>
                        <DataGridTextColumn Header="Запросов" Binding="{Binding TotalRequests}" Width="90"/>
                        <DataGridTextColumn Header="Успешных" Binding="{Binding SuccessfulRequests}" Width="90"/>
                        <DataGridTextColumn Header="Ошибок" Binding="{Binding FailedRequests}" Width="90"/>
                        <DataGridTextColumn Header="Avg, мс" Binding="{Binding AverageResponseTimeMs}" Width="90"/>
                        <DataGridTextColumn Header="Min, мс" Binding="{Binding MinResponseTimeMs}" Width="90"/>
                        <DataGridTextColumn Header="Max, мс" Binding="{Binding MaxResponseTimeMs}" Width="90"/>
                        <DataGridTextColumn Header="RPS" Binding="{Binding RequestsPerSecond}" Width="90"/>
                        <DataGridTextColumn Header="Байты" Binding="{Binding TotalBytesReceived}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
